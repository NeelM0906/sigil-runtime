{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bomba.sr/contracts/search-plan.schema.json",
  "title": "SearchPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "query",
    "intent",
    "scope",
    "fileTypes",
    "escalationAllowed"
  ],
  "properties": {
    "query": {
      "type": "string",
      "minLength": 1
    },
    "intent": {
      "type": "string",
      "enum": [
        "symbol_lookup",
        "flow_trace",
        "config_lookup",
        "test_lookup",
        "broad_discovery"
      ]
    },
    "scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "fileTypes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_+-]+$"
      }
    },
    "escalationAllowed": {
      "type": "boolean"
    },
    "escalationMode": {
      "type": "string",
      "enum": ["strict", "balanced", "aggressive"],
      "default": "balanced"
    }
  }
}
