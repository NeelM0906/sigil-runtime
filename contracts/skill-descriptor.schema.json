{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bomba.sigil/contracts/skill-descriptor.schema.json",
  "title": "SkillDescriptor",
  "type": "object",
  "required": [
    "skill_id",
    "version",
    "name",
    "description",
    "source",
    "body_text",
    "intent_tags",
    "tools_required",
    "risk_level",
    "default_enabled",
    "user_invocable",
    "disable_model_invocation",
    "command_arg_mode",
    "eligibility",
    "metadata"
  ],
  "properties": {
    "skill_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "enum": ["filesystem", "database"] },
    "source_path": { "type": ["string", "null"] },
    "body_text": { "type": "string" },
    "intent_tags": { "type": "array", "items": { "type": "string" } },
    "tools_required": { "type": "array", "items": { "type": "string" } },
    "risk_level": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "default_enabled": { "type": "boolean" },
    "user_invocable": { "type": "boolean" },
    "disable_model_invocation": { "type": "boolean" },
    "command_dispatch": { "type": ["string", "null"] },
    "command_tool": { "type": ["string", "null"] },
    "command_arg_mode": { "type": "string" },
    "eligibility": {
      "type": "object",
      "properties": {
        "always": { "type": "boolean" },
        "os_filter": { "type": "array", "items": { "type": "string" } },
        "required_bins": { "type": "array", "items": { "type": "string" } },
        "any_bins": { "type": "array", "items": { "type": "string" } },
        "required_env": { "type": "array", "items": { "type": "string" } },
        "required_config": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["always", "os_filter", "required_bins", "any_bins", "required_env", "required_config"],
      "additionalProperties": false
    },
    "metadata": { "type": "object" }
  },
  "additionalProperties": false
}
