{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bomba.sigil/contracts/plugin-manifest.schema.json",
  "title": "PluginManifest",
  "type": "object",
  "required": ["plugin_id", "name", "version", "entry_module"],
  "properties": {
    "plugin_id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "entry_module": { "type": "string", "minLength": 1 },
    "config_schema": { "type": ["object", "null"] },
    "kind": { "type": ["string", "null"] },
    "skills_dir": { "type": ["string", "null"] }
  },
  "additionalProperties": true
}
