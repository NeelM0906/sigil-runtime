{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bomba.sr/contracts/search-result-pack.schema.json",
  "title": "SearchResultPack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planId",
    "executedAt",
    "pass",
    "results",
    "escalated"
  ],
  "properties": {
    "planId": {
      "type": "string",
      "format": "uuid"
    },
    "executedAt": {
      "type": "string",
      "format": "date-time"
    },
    "pass": {
      "type": "integer",
      "enum": [1, 2]
    },
    "escalated": {
      "type": "boolean"
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "lineStart",
          "lineEnd",
          "confidence",
          "rationale"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "lineStart": {
            "type": "integer",
            "minimum": 1
          },
          "lineEnd": {
            "type": "integer",
            "minimum": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "snippet": {
            "type": "string"
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
