{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/enrich-prompt.sh",
            "timeout": 3,
            "statusMessage": "Enriching query context..."
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/auto-commit-push.sh",
            "timeout": 30,
            "statusMessage": "Committing and pushing task..."
          }
        ]
      }
    ]
  }
}
