# Required only for live OpenRouter capability fetch.
OPENROUTER_API_KEY=or-xxxxxxxxxxxxxxxx

# Optional override (defaults to https://openrouter.ai/api/v1)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional direct provider keys (runtime auto-selects Anthropic > OpenAI > OpenRouter > echo).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional OpenAI embeddings model (used by hybrid memory recall when OPENAI_API_KEY is set).
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Serena is enabled by default with edit tools enabled.
SERENA_BASE_URL=http://127.0.0.1:9121
SERENA_API_KEY=
SERENA_FALLBACK_TO_NATIVE=true

# Runtime settings
BOMBA_MODEL_ID=anthropic/claude-opus-4.6
BOMBA_WORKSPACE=/absolute/path/to/your/project
BOMBA_TURN_PROFILE=task_execution
BOMBA_RUNTIME_HOME=.runtime
BOMBA_LEARNING_AUTO_APPLY_CONFIDENCE=0.4
BOMBA_CAPABILITY_CACHE_TTL_SECONDS=21600
BOMBA_GENERIC_INFO_WEB_RETRIEVAL=true

# Pinecone (SAI Knowledge Base)
BOMBA_PINECONE_ENABLED=false
PINECONE_API_KEY=
PINECONE_API_KEY_STRATA=
BOMBA_PINECONE_DEFAULT_INDEX=ublib2
BOMBA_PINECONE_DEFAULT_NAMESPACE=longterm
# Optional JSON map fallback for host routing if index discovery is unavailable.
# Example: {"ublib2":"ublib2-xxxx.svc.aped-xxxx.pinecone.io"}
BOMBA_PINECONE_INDEX_HOSTS=
# Uses OPENAI_API_KEY declared above for Pinecone query embeddings.

# Voice (Bland.ai)
BOMBA_VOICE_ENABLED=false
BOMBA_VOICE_PROVIDER=bland
BLAND_API_KEY=

# Colosseum (CHDDIA² tournament engine)
BOMBA_COLOSSEUM_ENABLED=false
BOMBA_COLOSSEUM_MODEL_ID=gpt-4o-mini

# Prove-Ahead (competitive intelligence)
BOMBA_PROVE_AHEAD_ENABLED=false

# Zoom (transcript extraction skill/tool prerequisites)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
